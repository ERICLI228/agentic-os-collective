# ── 敏感配置（严禁提交）────────────────────────────────────────
.env
*.env.local
.env.production

# ── 数据库文件 ──────────────────────────────────────────────────
shared/data/*.db
shared/data/*.db-shm
shared/data/*.db-wal

# ── 执行日志（包含命令输出，可能含敏感信息）────────────────────
shared/logs/executions/*.log
shared/logs/executions/rotated/

# ── Python 编译产物 ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── 虚拟环境 ────────────────────────────────────────────────────
venv/
.venv/
env/

# ── macOS ────────────────────────────────────────────────────────
.DS_Store
backups/*.tar.gz
