# =============================================================
#  agentic-os-collective — 环境变量模板
#  使用方法：cp .env.example .env  然后填写真实值
#  .env 已加入 .gitignore，严禁提交真实密钥到 git
# =============================================================

# ── 路径配置（通常不需要修改）──────────────────────────────────
WORKSPACE_DIR=${HOME}/agentic-os-collective
DB_PATH=${HOME}/agentic-os-collective/shared/data/agentic.db

# ── 内部服务 ────────────────────────────────────────────────────
API_BASE=http://localhost:5001
API_HOST=127.0.0.1        # ⚠️ 不要改成 0.0.0.0，避免公网暴露
API_PORT=5001

# ── 外部 API 密钥（填写真实值，不要留空格）─────────────────────
FEISHU_WEBHOOK_URL=
MINIMAX_API_KEY=
SEEDANCE_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
GLM_API_KEY=

# ── TK 运营参数 ─────────────────────────────────────────────────
TK_TRENDING_THRESHOLD=3000000   # 爆款播放量阈值
TK_UPDATE_INTERVAL=7200         # 热门监控间隔（秒）

# ── 日志参数 ────────────────────────────────────────────────────
LOG_MAX_SIZE_MB=10
LOG_ROTATION_DAYS=30
