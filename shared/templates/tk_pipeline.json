{
  "name": "TK东南亚3C运营流水线",
  "version": "1.1",
  "project": "tk",
  "description": "TikTok东南亚5国3C品类自动运营流水线",
  "stages": [
    {
      "id": "MS-1",
      "name": "热门监控",
      "executor": "OpenClaw",
      "command": "bash ~/.agents/skills/proactive-operator/proactive-operator.sh",
      "expected_artifacts": ["report_*.md", "trending_products.json"],
      "timeout": 600,
      "decision_point": false,
      "description": "监控TikTok热门3C产品"
    },
    {
      "id": "MS-2",
      "name": "爆款分析",
      "executor": "OpenClaw",
      "command": "python3 ~/.openclaw/scripts/analyze_trending.py",
      "expected_artifacts": ["analysis_report.json", "product_recommendations.yaml"],
      "timeout": 300,
      "decision_point": true,
      "question": "是否选择以下产品进行推广？",
      "options": [
        {"label": "确认", "action": "continue", "next_stage": "MS-3"},
        {"label": "重新分析", "action": "retry", "next_stage": "MS-1"}
      ],
      "description": "分析爆款特征，生成选品建议"
    },
    {
      "id": "MS-3",
      "name": "内容制作",
      "executor": "OpenClaw",
      "command": "python3 ~/.openclaw/scripts/generate_content.py",
      "expected_artifacts": ["video_scripts.json", "content_calendar.yaml"],
      "timeout": 300,
      "decision_point": false,
      "description": "生成短视频脚本"
    },
    {
      "id": "MS-4",
      "name": "发布与追踪",
      "executor": "OpenClaw",
      "command": "python3 ~/.openclaw/scripts/publish_track.py",
      "expected_artifacts": ["publish_status.json", "performance_data.json"],
      "timeout": 600,
      "decision_point": false,
      "description": "自动发布并追踪数据"
    },
    {
      "id": "MS-5",
      "name": "周报生成",
      "executor": "OpenClaw",
      "command": "bash ~/.openclaw/scripts/feishu/daily-report.sh",
      "expected_artifacts": ["weekly_report.md"],
      "timeout": 120,
      "decision_point": false,
      "description": "生成周报并推送到飞书"
    }
  ]
}