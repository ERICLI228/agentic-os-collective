        "region": ["Indonesia", "Vietnam", "Thailand", "Philippines", "Malaysia"],
        "region_codes": ["id", "vn", "th", "ph", "my"],
        "category": "3C Electronics"
    },
    
    "watch_categories": [
        "laptop",
        "phone case", 
        "earbuds",
        "charger",
        "smart watch",
        "cable",
        "usb",
        "power bank",
        "keyboard",
        "mouse",
        "speaker",
        "tablet",
        "screen protector",
        "phone holder",
        "ring light",
        "selfie stick"
    ],
    
    "watch_keywords": [
        "laptop",
        "charger",
        "earbuds",
        "smartwatch",
        "phone case",
        "数据线",
        "充电宝",
        "键盘",
        "鼠标",
        "音响"
    ],
    
    "notification": {
        "feishu_webhook": "",
        "enabled": true
